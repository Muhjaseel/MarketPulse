# =====================================================================
# MarketPulse — environment overrides for docker/docker-compose.yaml
# Copy to `.env` in the repo root and adjust. `.env` itself is
# gitignored — never commit real credentials.
# =====================================================================

# --- Redpanda ---
REDPANDA_IMAGE_TAG=v23.3.5
REDPANDA_CONSOLE_IMAGE_TAG=v2.4.3
REDPANDA_EXTERNAL_PORT=19092
REDPANDA_CONSOLE_PORT=8888

# --- Postgres (Airflow metadata) ---
POSTGRES_IMAGE_TAG=15-alpine
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# --- Airflow ---
# NOTE: the admin/admin default below is fine for a local Docker Compose
# sandbox but must never be used anywhere reachable from a network.
AIRFLOW_IMAGE_TAG=2.9.2-python3.10
AIRFLOW_WEB_PORT=8080
AIRFLOW_UID=50000
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=
AIRFLOW_WEBSERVER_SECRET_KEY=marketpulse_dev_secret_key
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@marketpulse.local

# --- OpenLineage ---
# "console" logs lineage events to the task logs with zero extra infra.
# Switch to "http" and set OPENLINEAGE_URL once you run a real collector
# (e.g. Marquez) if you want a queryable lineage graph.
OPENLINEAGE_TRANSPORT_TYPE=console
OPENLINEAGE_URL=

# --- Dashboard ---
DASHBOARD_PORT=8501
